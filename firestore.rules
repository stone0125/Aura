// =============================================================================
// firestore.rules — Firestore Security Rules
// Firestore 安全规则
//
// Defines access control for all Firestore collections. Key principles:
// - User data isolation: users can only access their own data
// - Input validation: habits must have valid name and category
// - Immutability: history records cannot be updated (only created/deleted)
// - Server-only writes: usage counters can only be written by admin SDK
// - Default deny: all unmatched paths are denied access
//
// Data structure:
//   users/{userId}                    — User profile (用户资料)
//   users/{userId}/habits/{habitId}   — Habits (习惯)
//   users/{userId}/habits/{id}/history/{date} — Completion records (完成记录)
//   users/{userId}/dailyReviews/{date} — AI daily reviews (AI 每日回顾)
//   users/{userId}/habitScores/{id}   — AI habit scores (AI 习惯评分)
//   users/{userId}/healthCorrelations/{id} — Health analysis (健康分析)
//
// 定义所有 Firestore 集合的访问控制。关键原则：
// - 用户数据隔离：用户只能访问自己的数据
// - 输入验证：习惯必须有有效的名称和类别
// - 不可变性：历史记录不能更新（只能创建/删除）
// - 仅服务器写入：使用量计数器只能由 admin SDK 写入
// - 默认拒绝：所有未匹配的路径都拒绝访问
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    // 辅助函数：检查用户是否已通过身份验证
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to validate habit data
    function isValidHabit() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'category'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.category is string
        && data.category in ['health', 'learning', 'productivity', 'mindfulness', 'fitness'];
    }
    
    // User documents
    match /users/{userId} {
      // Only the owner can read/write their user document
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['createdAt', 'tierCache', 'isPro']));
      allow delete: if isOwner(userId); // Allow account deletion
      
      // Habits subcollection
      match /habits/{habitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHabit();
        allow update: if isOwner(userId) && isValidHabit();
        allow delete: if isOwner(userId);
        
        // History subcollection (completion records)
        match /history/{date} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && request.resource.data.keys().hasAll(['completedAt'])
            && request.resource.data.completedAt is timestamp;
          allow update: if false; // History should be immutable
          allow delete: if isOwner(userId); // Allow undo
        }
      }

      // Daily reviews subcollection (AI-generated daily reports)
      match /dailyReviews/{date} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId); // Allow owner to delete (needed for account deletion)
      }

      // Habit scores subcollection (AI-generated scores)
      match /habitScores/{habitId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId); // Allow owner to delete (needed for account deletion)

        match /history/{date} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if false;
          allow delete: if isOwner(userId);
        }
      }

      // Health correlations subcollection
      match /healthCorrelations/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId); // Allow owner to delete (needed for account deletion)
      }

      // Usage counters subcollection (server-side subscription enforcement)
      match /usageCounters/{counterId} {
        allow read: if isOwner(userId);
        allow create: if false; // Only server (admin SDK) can create
        allow update: if false; // Only server (admin SDK) can update
        allow delete: if isOwner(userId); // Allow owner to delete (needed for account deletion)
      }
    }
    
    // Support messages (submitted only via Cloud Function — admin SDK bypasses rules)
    // 支持消息（仅通过 Cloud Function 提交 — admin SDK 绕过规则）
    match /supportMessages/{messageId} {
      allow read, create, update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
